# --- Postgres connection (app user) ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=ragdb
PGUSER=raguser
PGPASSWORD=ragpass

# --- Embedding model (local, multilingual) ---
# bge-m3 = 1024 dims, strong Thai + English. Must match db/schema.sql vector(N).
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

# --- Corpus ---
# Default folder ingested when `python -m src.ingest` is run with no args.
CORPUS_DIR=data

# --- Chunking ---
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# --- Retrieval ---
TOP_K=5

# --- Generation (Claude API) ---
# Get a key at https://console.anthropic.com  ->  export it here
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
